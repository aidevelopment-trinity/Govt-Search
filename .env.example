# Federal contract search. Keep the real value in .env.local locally and in
# Vercel project environment variables in production.
SAM_API_KEY=

# Optional site-wide password protection. Set these in Vercel to enable the
# browser password prompt.
APP_BASIC_AUTH_USERNAME=admin
APP_BASIC_AUTH_PASSWORD=

# Supabase will be added when the project is linked to the correct account.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for Vercel Cron to call /api/cron/gov-monitor.
CRON_SECRET=

# Optional Google Docs draft creation. Create a Google Cloud service account,
# enable Drive API and Docs API, share the target Drive folder with the service
# account email, then set these in Vercel.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DOC_REVIEWER_EMAIL=
