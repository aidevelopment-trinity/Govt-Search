# Federal contract search. Keep the real value in .env.local locally and in
# Vercel project environment variables in production.
SAM_API_KEY=

# Optional site-wide password protection. Set these in Vercel to enable the
# browser password prompt.
APP_BASIC_AUTH_USERNAME=admin
APP_BASIC_AUTH_PASSWORD=

# Supabase will be added when the project is linked to the correct account.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
